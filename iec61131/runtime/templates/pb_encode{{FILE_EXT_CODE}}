END_FUNCTION

FUNCTION pb_enc_bytes : BOOL (*Internal bytes encoder*)
VAR_IN_OUT
    field : pb_field_iter_struct;
    stream : pb_ostream_struct;
END_VAR
VAR
    bytes : REFERENCE TO pb_bytes_array_struct;
END_VAR

    bytes{{FIELD_PTR_ACCESS}}field.pData;
    
    IF field.pData = 0 THEN
        (* Treat null pointer as an empty bytes field *)
        pb_enc_bytes := pb_encode_string(0, 0, stream);
        RETURN;
    END_IF;
    
    IF (PB_ATYPE(field.type) = PB_ATYPE_STATIC) AND 
       (bytes.size > field.data_size - SIZEOF(pb_bytes_array_struct)) THEN
        pb_enc_bytes := FALSE;
        RETURN;
    END_IF;
    
    pb_enc_bytes := pb_encode_string(ADR(bytes.bytes), bytes.size, stream);
END_FUNCTION

FUNCTION pb_enc_string : BOOL (*Internal string encoder*)
VAR_IN_OUT
    field : pb_field_iter_struct;
    stream : pb_ostream_struct;
END_VAR
VAR
    size : {{TYPE_SIZE}};
    max_size : {{TYPE_SIZE}};
    str : UDINT; (* const char pointer *)
    p : REFERENCE TO USINT;
END_VAR

    size := 0;
    max_size := field.data_size;
    str := field.pData;
    
    IF PB_ATYPE(field.type) = PB_ATYPE_POINTER THEN
        max_size := {{SIZE_MAX_VALUE}};
    ELSE
        IF max_size = 0 THEN
            pb_enc_string := FALSE;
            RETURN;
        END_IF;
        max_size := max_size - 1; (* Allow space for null terminator *)
    END_IF;

    IF str = 0 THEN
        size := 0; (* Treat null pointer as an empty string *)
    ELSE
        p{{FIELD_PTR_ACCESS}}str;
        (* strnlen() is not always available, so just use a loop *)
        WHILE (size < max_size) AND (p <> 0) DO
            size := size + 1;
            p{{FIELD_PTR_ACCESS}}(str + size);
        END_WHILE;

        IF p <> 0 THEN
            pb_enc_string := FALSE; (* Unterminated string *)
            RETURN;
        END_IF;
    END_IF;

    pb_enc_string := pb_encode_string(str, size, stream);
END_FUNCTION

FUNCTION pb_enc_submessage : BOOL (*Internal submessage encoder*)
VAR_IN_OUT
    field : pb_field_iter_struct;
    stream : pb_ostream_struct;
END_VAR

    IF field.submsg_desc = 0 THEN
        pb_enc_submessage := FALSE;
        RETURN;
    END_IF;
    
    pb_enc_submessage := pb_encode_submessage(field.submsg_desc, field.pData, stream);
END_FUNCTION

FUNCTION pb_enc_fixed_length_bytes : BOOL (*Internal fixed length bytes encoder*)
VAR_IN_OUT
    field : pb_field_iter_struct;
    stream : pb_ostream_struct;
END_VAR

    pb_enc_fixed_length_bytes := pb_encode_string(field.pData, field.data_size, stream);
END_FUNCTION
