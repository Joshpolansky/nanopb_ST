FUNCTION encode_basic_field : BOOL (*Encode basic field types*)
VAR_IN_OUT
    field : pb_field_iter_struct;
    stream : pb_ostream_struct;
END_VAR

    IF field.pData = 0 THEN
        (* Missing pointer field *)
        encode_basic_field := TRUE;
        RETURN;
    END_IF;

    IF NOT pb_encode_tag_for_field(field, stream) THEN
        encode_basic_field := FALSE;
        RETURN;
    END_IF;

    CASE PB_LTYPE(field.type) OF
        PB_LTYPE_BOOL:
            encode_basic_field := pb_enc_bool(field, stream);

        PB_LTYPE_VARINT,
        PB_LTYPE_UVARINT,
        PB_LTYPE_SVARINT:
            encode_basic_field := pb_enc_varint(field, stream);

        PB_LTYPE_FIXED32,
        PB_LTYPE_FIXED64:
            encode_basic_field := pb_enc_fixed(field, stream);

        PB_LTYPE_BYTES:
            encode_basic_field := pb_enc_bytes(field, stream);

        PB_LTYPE_STRING:
            encode_basic_field := pb_enc_string(field, stream);

        PB_LTYPE_SUBMESSAGE,
        PB_LTYPE_SUBMSG_W_CB:
            encode_basic_field := pb_enc_submessage(field, stream);

        PB_LTYPE_FIXED_LENGTH_BYTES:
            encode_basic_field := pb_enc_fixed_length_bytes(field, stream);
        ELSE
            encode_basic_field := FALSE;
    END_CASE;
END_FUNCTION

FUNCTION encode_field : BOOL (*Encode single field*)
VAR_IN_OUT
    field : pb_field_iter_struct;
    stream : pb_ostream_struct;
END_VAR
VAR
    size_ptr : REFERENCE TO UDINT;
END_VAR

    (* Check field presence *)
    IF PB_HTYPE(field.type) = PB_HTYPE_ONEOF THEN
        size_ptr{{FIELD_PTR_ACCESS}}field.pSize;
        IF size_ptr <> field.tag THEN
            (* Different type oneof field *)
            encode_field := TRUE;
            RETURN;
        END_IF;
    ELSIF PB_HTYPE(field.type) = PB_HTYPE_OPTIONAL THEN
        IF field.pSize <> 0 THEN
            IF NOT safe_read_bool(field.pSize) THEN
                (* Missing optional field *)
                encode_field := TRUE;
                RETURN;
            END_IF;
        ELSIF PB_ATYPE(field.type) = PB_ATYPE_STATIC THEN
            (* Proto3 singular field - skip if default value *)
            (* For simplicity, we'll encode all proto3 fields *)
        END_IF;
    END_IF;

    IF field.pData = 0 THEN
        IF PB_HTYPE(field.type) = PB_HTYPE_REQUIRED THEN
            encode_field := FALSE; (* Missing required field *)
            RETURN;
        END_IF;
        (* Pointer field set to NULL *)
        encode_field := TRUE;
        RETURN;
    END_IF;

    (* Encode field contents *)
    IF PB_ATYPE(field.type) = PB_ATYPE_CALLBACK THEN
        (* Callbacks not supported in ST version *)
        (* Just Skip for now *)
        encode_field := TRUE;
    ELSIF PB_HTYPE(field.type) = PB_HTYPE_REPEATED THEN
        (* TODO Support arrays *)
        (* Arrays not fully supported in this simplified version *)
        encode_field := encode_basic_field(field, stream);
    ELSE
        encode_field := encode_basic_field(field, stream);
    END_IF;
END_FUNCTION

FUNCTION pb_encode : BOOL
VAR_INPUT
    fields : UDINT; (* const pb_msgdesc_t pointer *)
    src_struct : UDINT; (* const void pointer *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR
VAR
    iter : pb_field_iter_struct;
    msgdesc : REFERENCE TO pb_msgdesc_struct;
END_VAR

    msgdesc{{FIELD_PTR_ACCESS}}fields;
    IF NOT pb_field_iter_begin_const(src_struct, iter, msgdesc) THEN
        pb_encode := TRUE; (* Empty message type *)
        RETURN;
    END_IF;
    
    REPEAT
        IF PB_LTYPE(iter.type) = PB_LTYPE_EXTENSION THEN
            (* Extension fields not supported in ST version *)
            pb_encode := FALSE;
            RETURN;
        ELSE
            (* Regular field *)
            IF NOT encode_field(iter, stream) THEN
                pb_encode := FALSE;
                RETURN;
            END_IF;
        END_IF;
    UNTIL NOT pb_field_iter_next(iter)
    END_REPEAT;
    
    pb_encode := TRUE;
END_FUNCTION

FUNCTION pb_encode_ex : BOOL (*Extended encode with flags*)
VAR_INPUT
    fields : UDINT; (* const pb_msgdesc_t pointer *)
    src_struct : UDINT; (* const void pointer *)
    flags : UDINT;
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR
VAR
    zero : USINT;
END_VAR

    IF (flags AND PB_ENCODE_DELIMITED) <> 0 THEN
        pb_encode_ex := pb_encode_submessage(fields, src_struct, stream);
    ELSIF (flags AND PB_ENCODE_NULLTERMINATED) <> 0 THEN
        zero := 0;
        IF NOT pb_encode(fields, src_struct, stream) THEN
            pb_encode_ex := FALSE;
            RETURN;
        END_IF;
        pb_encode_ex := pb_write(ADR(zero), 1, stream);
    ELSE
        pb_encode_ex := pb_encode(fields, src_struct, stream);
    END_IF;
END_FUNCTION

FUNCTION pb_get_encoded_size : BOOL (*Get encoded message size*)
VAR_INPUT
    fields : UDINT; (* const pb_msgdesc_t pointer *)
    src_struct : UDINT; (* const void pointer *)
END_VAR
VAR_IN_OUT
    size : {{TYPE_SIZE}}; (* size_t pointer *)
END_VAR
VAR
    stream : pb_ostream_struct;
END_VAR

    {{MEMSET_FUNC}}(ADR(stream), 0, SIZEOF(stream));
    stream.max_size := {{SIZE_MAX_VALUE}};
    
    IF NOT pb_encode(fields, src_struct, stream) THEN
        pb_get_encoded_size := FALSE;
        RETURN;
    END_IF;
    
    size := stream.bytes_written;
    pb_get_encoded_size := TRUE;
END_FUNCTION

FUNCTION pb_encode_varint_64 : BOOL (*Encode 64-bit varint from low/high 32-bit parts*)
VAR_INPUT
    low : UDINT; (* low 32 bits *)
    high : UDINT; (* high 32 bits *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    
VAR
    i : {{TYPE_SIZE}};
    buffer : ARRAY[0..9] OF USINT;
    byte : USINT;
END_VAR

    i := 0;
    byte := {{UDINT_TO_USINT}}(low AND 16#7F);
    low := SHR(low, 7);

    (* Process first 4 bytes (28 bits) from low part *)
    WHILE (i < 4) AND ((low <> 0) OR (high <> 0)) DO
        byte := byte OR 16#80;
        buffer[i] := byte;
        i := i + 1;
        byte := {{UDINT_TO_USINT}}(low AND 16#7F);
        low := SHR(low, 7);
    END_WHILE;

    (* Transition from low to high part *)
    IF high <> 0 THEN
        (* Combine remaining 4 bits from low with first 3 bits from high *)
        byte := byte OR {{UDINT_TO_USINT}}(SHL(high AND 16#07, 4));
        high := SHR(high, 3);

        (* Continue with remaining high bits *)
        WHILE high <> 0 DO
            byte := byte OR 16#80;
            buffer[i] := byte;
            i := i + 1;
            byte := {{UDINT_TO_USINT}}(high AND 16#7F);
            high := SHR(high, 7);
        END_WHILE;
    END_IF;

    buffer[i] := byte;
    i := i + 1;

    pb_encode_varint_64 := pb_write(ADR(buffer), i, stream);
END_FUNCTION

{{STRIP_64BIT_START}}
FUNCTION pb_encode_varint_native : BOOL (*Encode varint - Native 64-bit version*)
VAR_INPUT
    value : {{UINT64_TYPE}}; (* pb_uint64_t *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    
VAR
    byte : USINT;
END_VAR

    IF value <= 16#7F THEN
        (* Fast path: single byte *)
        byte := {{ULINT_TO_USINT}}(value);
        pb_encode_varint_native := pb_write(ADR(byte), 1, stream);
    ELSE
        pb_encode_varint_native := pb_encode_varint_64({{ULINT_TO_UDINT}}(value), {{ULINT_TO_UDINT}}(SHR(value, 32)), stream);
    END_IF;
END_FUNCTION
{{STRIP_64BIT_END}}

{{STRIP_NO64BIT_START}}
FUNCTION pb_encode_varint_native : BOOL (*Encode varint - 32-bit compatibility version*)
VAR_INPUT
    value : {{UINT64_TYPE}}; (* pb_uint64_t as array *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    
VAR
    byte : USINT;
    low_part : UDINT;
    high_part : UDINT;
END_VAR

    (* Extract low and high 32-bit parts from array *)
    low_part := value[0];
    high_part := value[1];
    
    IF (high_part = 0) AND (low_part <= 16#7F) THEN
        (* Fast path: single byte *)
        byte := {{UDINT_TO_USINT}}(low_part);
        pb_encode_varint_native := pb_write(ADR(byte), 1, stream);
    ELSE
        pb_encode_varint_native := pb_encode_varint_64(low_part, high_part, stream);
    END_IF;
END_FUNCTION
{{STRIP_NO64BIT_END}}

FUNCTION pb_encode_varint : BOOL (*Encode 32-bit varint - most common case*)
VAR_INPUT
    value : UDINT; (* uint32_t *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    
VAR
    i : {{TYPE_SIZE}};
    buffer : ARRAY[0..4] OF USINT;
    byte : USINT;
END_VAR

    IF value <= 16#7F THEN
        (* Fast path: single byte *)
        byte := {{UDINT_TO_USINT}}(value);
        pb_encode_varint := pb_write(ADR(byte), 1, stream);
        RETURN;
    ELSE 
        pb_encode_varint := pb_encode_varint_64(value, 0, stream);
    END_IF;
END_FUNCTION

{{STRIP_64BIT_START}}
FUNCTION pb_encode_svarint : BOOL (*Encode signed varint - Native 64-bit version*)
VAR_INPUT
    value : {{INT64_TYPE}}; (* pb_int64_t *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    
VAR
    zigzagged : {{UINT64_TYPE}};
    mask : {{UINT64_TYPE}};
END_VAR

    mask := SHR({{INT64_TO_UINT64}}(-1), 1); (* Satisfy clang -fsanitize=integer *)
    IF value < 0 THEN
        zigzagged := NOT (SHL({{INT64_TO_UINT64}}(value) AND mask, 1));
    ELSE
        zigzagged := SHL({{INT64_TO_UINT64}}(value), 1);
    END_IF;
    
    pb_encode_svarint := pb_encode_varint_native(zigzagged, stream);
END_FUNCTION
{{STRIP_64BIT_END}}

FUNCTION pb_encode_svarint_32 : BOOL (*Encode signed 32-bit varint using zigzag*)
VAR_INPUT
    value : DINT; (* int32_t *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    
VAR
    zigzagged : UDINT;
END_VAR

    (* Zigzag encoding: (n << 1) ^ (n >> 31) *)
    IF value < 0 THEN
        zigzagged := NOT (SHL({{DINT_TO_UDINT}}(value), 1));
    ELSE
        zigzagged := SHL({{DINT_TO_UDINT}}(value), 1);
    END_IF;
    
    pb_encode_svarint_32 := pb_encode_varint(zigzagged, stream);
END_FUNCTION

{{STRIP_NO64BIT_START}}
FUNCTION pb_encode_svarint_64_compat : BOOL (*Encode signed 64-bit varint using zigzag*)
VAR_INPUT
    low : UDINT; (* low 32 bits *)
    high : UDINT; (* high 32 bits *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    
VAR
    is_negative : BOOL;
    zigzag_low : UDINT;
    zigzag_high : UDINT;
END_VAR

    (* Check if negative (high bit of high part set) *)
    is_negative := (high AND 16#80000000) <> 0;
    
    IF is_negative THEN
        (* Zigzag encoding for negative: ~(n << 1) *)
        zigzag_low := NOT (SHL(low, 1));
        zigzag_high := NOT (SHL(high, 1));
        (* Handle carry from low to high *)
        IF (low AND 16#80000000) <> 0 THEN
            zigzag_high := zigzag_high + 1;
        END_IF;
    ELSE
        (* Zigzag encoding for positive: n << 1 *)
        zigzag_low := SHL(low, 1);
        zigzag_high := SHL(high, 1);
        (* Handle carry from low to high *)
        IF (low AND 16#80000000) <> 0 THEN
            zigzag_high := zigzag_high + 1;
        END_IF;
    END_IF;
    
    pb_encode_svarint_64_compat := pb_encode_varint_64(zigzag_low, zigzag_high, stream);
END_FUNCTION
{{STRIP_NO64BIT_END}}

{{STRIP_NO64BIT_START}}
FUNCTION pb_encode_svarint : BOOL (*Encode signed varint - 32-bit compatibility version*)
VAR_INPUT
    value : {{INT64_TYPE}}; (* pb_int64_t as array *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    
VAR
    zigzagged : {{UINT64_TYPE}};
    is_negative : BOOL;
    low_part : DINT;
    high_part : DINT;
END_VAR

    (* Extract signed 32-bit parts from array *)
    low_part := value[0];
    high_part := value[1];
    
    is_negative := (high_part < 0);
    
    IF is_negative THEN
        (* Zigzag encoding for negative numbers *)
        zigzagged[0] := NOT (SHL({{DINT_TO_UDINT}}(low_part), 1));
        zigzagged[1] := NOT (SHL({{DINT_TO_UDINT}}(high_part), 1));
    ELSE
        (* Zigzag encoding for positive numbers *)
        zigzagged[0] := SHL({{DINT_TO_UDINT}}(low_part), 1);
        zigzagged[1] := SHL({{DINT_TO_UDINT}}(high_part), 1);
    END_IF;
    
    pb_encode_svarint := pb_encode_varint_native(zigzagged, stream);
END_FUNCTION
{{STRIP_NO64BIT_END}}

FUNCTION pb_encode_fixed32 : BOOL (*Encode 32-bit fixed value*)
VAR_INPUT
    value : UDINT;
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    
VAR
    bytes : ARRAY[0..3] OF USINT;
END_VAR

    bytes[0] := {{UDINT_TO_USINT}}(value AND 16#FF);
    bytes[1] := {{UDINT_TO_USINT}}(SHR(value, 8) AND 16#FF);
    bytes[2] := {{UDINT_TO_USINT}}(SHR(value, 16) AND 16#FF);
    bytes[3] := {{UDINT_TO_USINT}}(SHR(value, 24) AND 16#FF);
    pb_encode_fixed32 := pb_write(ADR(bytes), 4, stream);
END_FUNCTION

