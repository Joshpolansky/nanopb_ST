{{PLATFORM_HEADER}}
(* nanoPB encode functions *)
(* Ported from nanoPB C library to {{PLATFORM_NAME}} IEC 61131-3 ST *)

FUNCTION buf_write : BOOL (*Internal buffer writing function*)
VAR_INPUT
    buf : UDINT; (* const pb_byte_t pointer *)
    count : {{TYPE_SIZE}}; (* size_t *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    
VAR
    dest : UDINT; (* pb_byte_t pointer *)
END_VAR

    dest := stream.state;
    stream.state := dest + count;
    
    {{MEMCPY_FUNC}}(dest, buf, count);
    
    buf_write := TRUE;
END_FUNCTION

FUNCTION pb_ostream_from_buffer : UDINT (*Create output stream from buffer*)
VAR_INPUT
    buf : UDINT; (* pb_byte_t pointer *)
    bufsize : {{TYPE_SIZE}}; (* size_t *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    
VAR
    marker : DINT;
END_VAR

    {{MEMSET_FUNC}}(ADR(stream), 0, SIZEOF(stream));
    marker := 1; (* Non-NULL marker for buffer stream *)
    stream.callback := ADR(marker);
    stream.state := buf;
    stream.max_size := bufsize;
    stream.bytes_written := 0;
    
    pb_ostream_from_buffer := ADR(stream);
END_FUNCTION

FUNCTION pb_write : BOOL (*Write data to output stream*)
VAR_INPUT
    buf : UDINT; (* const pb_byte_t pointer *)
    count : {{TYPE_SIZE}}; (* size_t *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    

    IF (count > 0) AND (stream.callback <> 0) THEN
        IF (stream.bytes_written + count < stream.bytes_written) OR
           (stream.bytes_written + count > stream.max_size) THEN
            pb_write := FALSE;
            stream.errmsg := 'Buffer overflow';
            RETURN;
        END_IF;

        IF NOT buf_write(buf, count, stream) THEN
            pb_write := FALSE;
            RETURN;
        END_IF;
    END_IF;
    
    stream.bytes_written := stream.bytes_written + count;
    pb_write := TRUE;
END_FUNCTION

FUNCTION safe_read_bool : BOOL (*Safely read bool value*)
VAR_INPUT
    pSize : UDINT; (* const void pointer *)
END_VAR
VAR
    p : REFERENCE TO USINT;
    i : UDINT;
END_VAR

    p{{FIELD_PTR_ACCESS}}pSize;
    FOR i := 0 TO SIZEOF(BOOL) - 1 DO
        IF p <> 0 THEN
            safe_read_bool := TRUE;
            RETURN;
        END_IF;
        (* Move to next byte *)
        p{{FIELD_PTR_ACCESS}}(pSize + i + 1);
    END_FOR;
    safe_read_bool := FALSE;
END_FUNCTION

