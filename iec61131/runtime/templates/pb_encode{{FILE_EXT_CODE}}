FUNCTION pb_enc_fixed : BOOL (*Internal fixed-size encoder*)
VAR_IN_OUT
    field : pb_field_iter_struct;
    stream : pb_ostream_struct;
END_VAR
VAR
    value32_ptr : REFERENCE TO UDINT;
END_VAR

    CASE field.data_size OF
        4:
            value32_ptr{{FIELD_PTR_ACCESS}}field.pData;
            pb_enc_fixed := pb_encode_fixed32(value32_ptr, stream);
        8:
            pb_enc_fixed := pb_encode_fixed64(field.pData, stream);
        ELSE
            pb_enc_fixed := FALSE;
