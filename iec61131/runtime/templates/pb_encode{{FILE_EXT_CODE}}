FUNCTION pb_encode_fixed64 : BOOL (*Encode 64-bit fixed value - Native 64-bit version*)
VAR_INPUT
    low_part : UDINT; (* const void pointer *)
    high_part : UDINT; (* const void pointer *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    
VAR
    bytes : ARRAY[0..7] OF USINT;
END_VAR

    bytes[0] := {{ULINT_TO_USINT}}(low_part AND 16#FF);
    bytes[1] := {{ULINT_TO_USINT}}(SHR(low_part, 8) AND 16#FF);
    bytes[2] := {{ULINT_TO_USINT}}(SHR(low_part, 16) AND 16#FF);
    bytes[3] := {{ULINT_TO_USINT}}(SHR(low_part, 24) AND 16#FF);
    bytes[4] := {{ULINT_TO_USINT}}(high_part AND 16#FF);
    bytes[5] := {{ULINT_TO_USINT}}(SHR(high_part, 8) AND 16#FF);
    bytes[6] := {{ULINT_TO_USINT}}(SHR(high_part, 16) AND 16#FF);
    bytes[7] := {{ULINT_TO_USINT}}(SHR(high_part, 24) AND 16#FF);
    pb_encode_fixed64 := pb_write(ADR(bytes), 8, stream);
END_FUNCTION
{{STRIP_64BIT_END}}

{{STRIP_NO64BIT_START}}
FUNCTION pb_encode_fixed64 : BOOL (*Encode 64-bit fixed value - 32-bit compatibility version*)
VAR_INPUT
    value : UDINT; (* const void pointer *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    
VAR
    val : {{UINT64_TYPE}}; (* Array representing 64-bit value *)
    bytes : ARRAY[0..7] OF USINT;
    val_ptr : REFERENCE TO {{UINT64_TYPE}};
    low_part : UDINT;
    high_part : UDINT;
END_VAR

    val_ptr{{FIELD_PTR_ACCESS}}value;
    val := val_ptr;
    
    (* Extract 32-bit parts from array *)
    low_part := val[0];
    high_part := val[1];
    
    (* Encode low 32 bits *)
    bytes[0] := {{UDINT_TO_USINT}}(low_part AND 16#FF);
    bytes[1] := {{UDINT_TO_USINT}}(SHR(low_part, 8) AND 16#FF);
    bytes[2] := {{UDINT_TO_USINT}}(SHR(low_part, 16) AND 16#FF);
    bytes[3] := {{UDINT_TO_USINT}}(SHR(low_part, 24) AND 16#FF);
    
    (* Encode high 32 bits *)
    bytes[4] := {{UDINT_TO_USINT}}(high_part AND 16#FF);
    bytes[5] := {{UDINT_TO_USINT}}(SHR(high_part, 8) AND 16#FF);
    bytes[6] := {{UDINT_TO_USINT}}(SHR(high_part, 16) AND 16#FF);
    bytes[7] := {{UDINT_TO_USINT}}(SHR(high_part, 24) AND 16#FF);
    
    pb_encode_fixed64 := pb_write(ADR(bytes), 8, stream);
END_FUNCTION
{{STRIP_NO64BIT_END}}

FUNCTION pb_encode_tag : BOOL (*Encode field tag and wire type*)
VAR_INPUT
    wiretype : USINT; (* pb_wire_type_t *)
    field_number : UDINT; (* uint32_t *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    
VAR
    tag : UDINT;
END_VAR
    tag := SHL(field_number, 3) OR wiretype;
    pb_encode_tag := pb_encode_varint(tag, stream);
END_FUNCTION

FUNCTION pb_encode_tag_for_field : BOOL (*Encode tag for field*)
VAR_IN_OUT
    field : pb_field_iter_struct;
    stream : pb_ostream_struct;
END_VAR
VAR
    wiretype : DINT;
END_VAR

    CASE PB_LTYPE(field.type) OF
        PB_LTYPE_BOOL,
        PB_LTYPE_VARINT,
        PB_LTYPE_UVARINT,
        PB_LTYPE_SVARINT:
            wiretype := PB_WT_VARINT;

        PB_LTYPE_FIXED32:
            wiretype := PB_WT_32BIT;

        PB_LTYPE_FIXED64:
            wiretype := PB_WT_64BIT;

        PB_LTYPE_BYTES,
        PB_LTYPE_STRING,
        PB_LTYPE_SUBMESSAGE,
        PB_LTYPE_SUBMSG_W_CB,
        PB_LTYPE_FIXED_LENGTH_BYTES:
            wiretype := PB_WT_STRING;
        ELSE
            pb_encode_tag_for_field := FALSE;
            RETURN;
    END_CASE;
    
    pb_encode_tag_for_field := pb_encode_tag({{DINT_TO_USINT}}(wiretype), field.tag, stream);
END_FUNCTION

FUNCTION pb_encode_string : BOOL (*Encode string with length prefix*)
VAR_INPUT
    buffer : UDINT; (* const pb_byte_t pointer *)
    size : {{TYPE_SIZE}}; (* size_t *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    

    IF NOT pb_encode_varint(size, stream) THEN
        pb_encode_string := FALSE;
        RETURN;
    END_IF;
    
    pb_encode_string := pb_write(buffer, size, stream);
END_FUNCTION

FUNCTION pb_encode_submessage : BOOL (*Encode submessage*)
VAR_INPUT
    fields : UDINT; (* const pb_msgdesc_t pointer *)
    src_struct : UDINT; (* const void pointer *)
END_VAR
VAR_IN_OUT
    stream : pb_ostream_struct;
END_VAR    
VAR
    substream : pb_ostream_struct;
    msgdesc : REFERENCE TO pb_msgdesc_struct;
END_VAR

    (* First calculate the message size using a non-writing substream *)
    {{MEMSET_FUNC}}(ADR(substream), 0, SIZEOF(substream));
    substream.max_size := {{SIZE_MAX_VALUE}};
    
    msgdesc{{FIELD_PTR_ACCESS}}fields;
    IF NOT pb_encode(fields, src_struct, substream) THEN
        pb_encode_submessage := FALSE;
        RETURN;
    END_IF;
    
    IF NOT pb_encode_varint(substream.bytes_written, stream) THEN
        pb_encode_submessage := FALSE;
        RETURN;
    END_IF;
    
    IF stream.callback = 0 THEN
        pb_encode_submessage := pb_write(0, substream.bytes_written, stream);
        RETURN;
    END_IF;
    
    IF stream.bytes_written + substream.bytes_written > stream.max_size THEN
        pb_encode_submessage := FALSE;
        RETURN;
    END_IF;
        
    pb_encode_submessage := pb_encode(fields, src_struct, stream);
END_FUNCTION

FUNCTION pb_enc_bool : BOOL (*Internal bool encoder*)
VAR_IN_OUT
    field : pb_field_iter_struct;
    stream : pb_ostream_struct;
END_VAR
VAR
    value : UDINT;
END_VAR

    value := {{BOOL_TO_UDINT}}(safe_read_bool(field.pData));
    pb_enc_bool := pb_encode_varint(value, stream);
END_FUNCTION

FUNCTION pb_enc_varint : BOOL (*Internal varint encoder*)
VAR_IN_OUT
    field : pb_field_iter_struct;
    stream : pb_ostream_struct;
END_VAR
VAR
    value8_ptr : REFERENCE TO USINT;
    value16_ptr : REFERENCE TO UINT;
    value32_ptr : REFERENCE TO UDINT;
{{STRIP_64BIT_START}}
    value64_ptr : REFERENCE TO ULINT;
{{STRIP_64BIT_END}}
    svalue8_ptr : REFERENCE TO SINT;
    svalue16_ptr : REFERENCE TO INT;
    svalue32_ptr : REFERENCE TO DINT;
{{STRIP_64BIT_START}}
    svalue64_ptr : REFERENCE TO LINT;
{{STRIP_64BIT_END}}
{{STRIP_NO64BIT_START}}
    low_part : UDINT;
    high_part : UDINT;
{{STRIP_NO64BIT_END}}
END_VAR

    IF PB_LTYPE(field.type) = PB_LTYPE_UVARINT THEN
        CASE field.data_size OF
            1:
                value8_ptr{{FIELD_PTR_ACCESS}}field.pData;
                pb_enc_varint := pb_encode_varint({{USINT_TO_UDINT}}(value8_ptr), stream);
            2:
                value16_ptr{{FIELD_PTR_ACCESS}}field.pData;
                pb_enc_varint := pb_encode_varint({{UINT_TO_UDINT}}(value16_ptr), stream);
            4:
                value32_ptr{{FIELD_PTR_ACCESS}}field.pData;
                pb_enc_varint := pb_encode_varint(value32_ptr, stream);
            8:
                (* Only 8-byte fields need special 64-bit handling *)
{{STRIP_64BIT_START}}
                value64_ptr{{FIELD_PTR_ACCESS}}field.pData;
                pb_enc_varint := pb_encode_varint_64({{ULINT_TO_UDINT}}(value64_ptr), {{ULINT_TO_UDINT}}(SHR(value64_ptr, 32)), stream);
{{STRIP_64BIT_END}}
{{STRIP_NO64BIT_START}}
                value32_ptr{{FIELD_PTR_ACCESS}}field.pData;
                low_part := value32_ptr;
                value32_ptr{{FIELD_PTR_ACCESS}}(field.pData + 4);
                high_part := value32_ptr;
                pb_enc_varint := pb_encode_varint_64(low_part, high_part, stream);
{{STRIP_NO64BIT_END}}
            ELSE
                pb_enc_varint := FALSE;
                RETURN;
        END_CASE;
    ELSE
        CASE field.data_size OF
            1:
                svalue8_ptr{{FIELD_PTR_ACCESS}}field.pData;
                IF PB_LTYPE(field.type) = PB_LTYPE_SVARINT THEN
                    pb_enc_varint := pb_encode_svarint_32({{SINT_TO_DINT}}(svalue8_ptr), stream);
                ELSE
                    pb_enc_varint := pb_encode_varint({{SINT_TO_UDINT}}(svalue8_ptr), stream);
                END_IF;
            2:
                svalue16_ptr{{FIELD_PTR_ACCESS}}field.pData;
                IF PB_LTYPE(field.type) = PB_LTYPE_SVARINT THEN
                    pb_enc_varint := pb_encode_svarint_32({{INT_TO_DINT}}(svalue16_ptr), stream);
                ELSE
                    pb_enc_varint := pb_encode_varint({{INT_TO_UDINT}}(svalue16_ptr), stream);
                END_IF;
            4:
                svalue32_ptr{{FIELD_PTR_ACCESS}}field.pData;
                IF PB_LTYPE(field.type) = PB_LTYPE_SVARINT THEN
                    pb_enc_varint := pb_encode_svarint_32(svalue32_ptr, stream);
                ELSE
                    pb_enc_varint := pb_encode_varint({{DINT_TO_UDINT}}(svalue32_ptr), stream);
