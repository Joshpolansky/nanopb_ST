{{STRIP_64BIT_START}}
                svalue64_ptr{{FIELD_PTR_ACCESS}}field.pData;
                IF PB_LTYPE(field.type) = PB_LTYPE_SVARINT THEN
                    pb_enc_varint := pb_encode_svarint(svalue64_ptr, stream);
                ELSE
                    pb_enc_varint := pb_encode_varint_64({{LINT_TO_UDINT}}(svalue64_ptr), {{LINT_TO_UDINT}}(SHR(svalue64_ptr, 32)), stream);
                END_IF;
{{STRIP_64BIT_END}}
{{STRIP_NO64BIT_START}}
                (* For B&R: read as two 32-bit signed values *)
                svalue32_ptr{{FIELD_PTR_ACCESS}}field.pData;
                low_part := {{DINT_TO_UDINT}}(svalue32_ptr);
                svalue32_ptr{{FIELD_PTR_ACCESS}}(field.pData + 4);
                high_part := {{DINT_TO_UDINT}}(svalue32_ptr);
                IF PB_LTYPE(field.type) = PB_LTYPE_SVARINT THEN
                    pb_enc_varint := pb_encode_svarint_64_compat(low_part, high_part, stream);
